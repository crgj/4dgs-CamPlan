{
  "name": "camplan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CamPlan — Web 端相机机位规划、灯光布置与覆盖度评估工具",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "format": "prettier --write .",
    "gen-library": "node scripts/gen-library-presets.mjs"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-virtual": "3.14.3",
    "dockview": "^6.6.1",
    "postprocessing": "^6.39.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0",
    "three-gpu-pathtracer": "^0.0.24",
    "three-mesh-bvh": "^0.9.10",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/ui": "4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.4",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
